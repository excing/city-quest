<!-- Callers: pages/map. Signature 点位签. -->
<view class="preview-card" bindtap="onTap" hover-class="preview-card--pressed">
  <view class="preview-card__bar" style="background-color: {{typeColor}};"></view>
  <view class="preview-card__body">
    <view class="preview-card__title-row">
      <text class="preview-card__title">{{name}}</text>
      <text class="preview-card__chevron">›</text>
    </view>
    <view class="preview-card__type-row">
      <text class="preview-card__dot" style="color: {{typeColor}};">●</text>
      <text class="preview-card__type">{{typeName}}</text>
    </view>
    <text class="preview-card__intro" wx:if="{{intro}}">{{intro}}</text>
  </view>
</view>
