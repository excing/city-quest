/* Callers: preview-card component. Design tokens from app.wxss. */
.preview-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  min-height: 88rpx;
  background: var(--color-map-chrome);
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  animation: preview-card-in 180ms ease-out;
}

@keyframes preview-card-in {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.preview-card--pressed {
  opacity: 0.92;
}

.preview-card__bar {
  width: 10rpx;
  flex-shrink: 0;
  background: var(--color-primary);
}

.preview-card__body {
  flex: 1;
  min-width: 0;
  padding: 20rpx 24rpx;
}

.preview-card__title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.preview-card__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-card__chevron {
  color: var(--color-ink-muted);
  font-size: 36rpx;
  line-height: 1;
}

.preview-card__type-row {
  margin-top: 8rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.preview-card__dot {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 1.5;
}

.preview-card__type {
  flex-shrink: 0;
  color: var(--color-ink);
}

.preview-card__intro {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--color-ink-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
