.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: var(--color-fill);
}

.map {
  width: 100%;
  height: 100%;
}

.map-banner {
  position: absolute;
  top: 24rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 10;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.map-banner--loading {
  background: var(--color-map-chrome);
  color: var(--color-ink-secondary);
}

.map-banner--error {
  background: var(--color-danger-soft);
  color: var(--color-danger);
}

.map-empty {
  position: absolute;
  left: 50%;
  top: 42%;
  transform: translate(-50%, -50%);
  z-index: 10;
  width: 70%;
  padding: 40rpx 32rpx;
  background: var(--color-map-chrome);
  border-radius: var(--radius-lg);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.map-empty__title {
  font-size: 28rpx;
  color: var(--color-ink);
  margin-bottom: 20rpx;
}

.preview-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
  z-index: 20;
  display: flex;
  align-items: stretch;
  min-height: 128rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sheet);
  overflow: hidden;
}

.preview-card--pressed {
  opacity: 0.92;
}

.preview-card__bar {
  width: 12rpx;
  flex-shrink: 0;
}

.preview-card__body {
  flex: 1;
  min-width: 0;
  padding: 24rpx 8rpx 24rpx 24rpx;
}

.preview-card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-ink-secondary);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.preview-card__type {
  color: var(--color-ink-secondary);
}

.preview-card__sep {
  margin: 0 8rpx;
  color: var(--color-ink-muted);
}

.preview-card__intro {
  color: var(--color-ink-secondary);
}

.preview-card__chevron {
  align-self: center;
  padding: 0 24rpx;
  font-size: 40rpx;
  color: var(--color-ink-muted);
  line-height: 1;
}
