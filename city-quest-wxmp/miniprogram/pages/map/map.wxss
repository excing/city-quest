.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
  background: var(--color-paper);
}

.map-page__map {
  width: 100%;
  height: 100%;
}

.map-page__banner {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  border: 1rpx solid var(--color-line);
  box-shadow: var(--shadow-card);
  font-size: 26rpx;
  color: var(--color-ink);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.map-page__banner--error {
  background: var(--color-danger-soft);
  color: var(--color-danger);
}

.map-page__link {
  color: var(--color-primary);
  flex-shrink: 0;
}

.map-page__loading {
  position: absolute;
  left: 50%;
  top: 24rpx;
  transform: translateX(-50%);
  padding: 12rpx 28rpx;
  border-radius: var(--radius-pill);
  background: var(--color-map-chrome);
  border: 1rpx solid var(--color-line);
  font-size: 24rpx;
  color: var(--color-ink-secondary);
}

.map-page__preview {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}
