/* Callers: map page styles. Tokens from app.wxss. */
/* Tab page content area is already above tabBar — fill it, avoid 100vh overflow. */
page {
  height: 100%;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100%;
  background: var(--color-paper);
  overflow: hidden;
}

.map-page__map {
  width: 100%;
  height: 100%;
}

.map-page__banner {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  border: 1rpx solid var(--color-line);
  box-shadow: var(--shadow-card);
  font-size: 26rpx;
  color: var(--color-ink);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  z-index: 5;
}

.map-page__banner--error {
  background: var(--color-danger-soft);
  color: var(--color-danger);
}

.map-page__link {
  color: var(--color-primary);
  flex-shrink: 0;
}

.map-page__loading {
  position: absolute;
  left: 50%;
  top: 24rpx;
  transform: translateX(-50%);
  padding: 12rpx 28rpx;
  border-radius: var(--radius-pill);
  background: var(--color-map-chrome);
  border: 1rpx solid var(--color-line);
  font-size: 24rpx;
  color: var(--color-ink-secondary);
  z-index: 5;
}

.map-page__legend {
  position: absolute;
  left: 32rpx;
  top: 24rpx;
  max-width: calc(100% - 64rpx);
  padding: 12rpx 16rpx;
  border-radius: var(--radius-md);
  background: var(--color-map-chrome);
  border: 1rpx solid var(--color-line);
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  z-index: 4;
}

.map-page__legend-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
}

.map-page__legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.map-page__legend-dot {
  font-size: 20rpx;
  line-height: 1;
}

.map-page__legend-name {
  font-size: 22rpx;
  color: var(--color-ink);
}

.map-page__legend-close {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--color-ink-muted);
  padding: 4rpx 8rpx;
}

.map-page__preview {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  /* Tab page content is above tab bar; keep ≥16px from bottom chrome. */
  bottom: 32rpx;
  z-index: 10;
}
