.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: var(--color-fill);
}

.map {
  width: 100%;
  height: 100%;
}

.map-banner {
  position: absolute;
  top: 24rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 10;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.map-banner--loading {
  background: var(--color-map-chrome);
  color: var(--color-ink-secondary);
}

.map-banner--error {
  background: var(--color-danger-soft);
  color: var(--color-danger);
  border-color: transparent;
}

.map-empty {
  position: absolute;
  left: 50%;
  top: 42%;
  transform: translate(-50%, -50%);
  z-index: 10;
  width: 70%;
  padding: 40rpx 32rpx;
  background: var(--color-map-chrome);
  border-radius: var(--radius-lg);
  text-align: center;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(255, 255, 255, 0.65);
}

.map-empty__title {
  font-size: 28rpx;
  color: var(--color-ink);
  margin-bottom: 20rpx;
}

/* 点位签 dock：只负责贴底与边距，不参与卡片视觉 */
.preview-dock {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding-left: 32rpx;
  padding-right: 32rpx;
  /* cq-safe-bottom 追加底部安全区；再留一点与 Tab 的呼吸 */
  padding-top: 8rpx;
}

.preview-dock--pressed .preview-card {
  transform: scale(0.985);
  opacity: 0.96;
}

/* 纸面签本体：类型色竖条 + 白卡 + 轻边框 */
.preview-card {
  display: flex;
  align-items: stretch;
  min-height: 148rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sheet);
  border: 1rpx solid var(--color-line);
  overflow: hidden;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.preview-card__bar {
  width: 10rpx;
  flex-shrink: 0;
}

.preview-card__body {
  flex: 1;
  min-width: 0;
  padding: 28rpx 28rpx 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.preview-card__head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preview-card__name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
  color: var(--color-ink);
  letter-spacing: 0.2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-card__go {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 2rpx;
  padding: 6rpx 4rpx 6rpx 12rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-soft);
}

.preview-card__go-label {
  font-size: 22rpx;
  line-height: 1;
  color: var(--color-primary);
  font-weight: 500;
}

.preview-card__go-chevron {
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-primary);
  margin-top: -2rpx;
}

.preview-card__type {
  display: flex;
  align-items: center;
  min-height: 28rpx;
}

.preview-card__type-name {
  font-size: 22rpx;
  line-height: 1.2;
  color: var(--color-ink-secondary);
  letter-spacing: 0.5rpx;
}

.preview-card__intro {
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--color-ink-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
}
