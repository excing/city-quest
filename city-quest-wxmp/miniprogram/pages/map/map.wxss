.page {
  padding: 32rpx;
  min-height: 100vh;
  background: var(--color-paper);
  color: var(--color-ink);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.status {
  color: var(--color-ink-secondary);
  margin-bottom: 12rpx;
}

.meta {
  font-size: 24rpx;
  color: var(--color-ink-muted);
}

.error {
  color: var(--color-danger);
  margin: 16rpx 0;
}

.hint {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: var(--color-ink-muted);
  line-height: 1.5;
}
