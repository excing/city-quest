<view class="page">
  <view class="title">首页 · 地图</view>
  <view class="status">{{statusText}}</view>
  <view class="meta" wx:if="{{markerCount}}">markers: {{markerCount}}</view>
  <view class="error" wx:if="{{error}}">{{error}}</view>
  <button wx:if="{{error}}" size="mini" bindtap="onRetry">重试</button>
  <view class="hint">完整地图 UI 见 PRD 阶段 A；当前为架构骨架。</view>
</view>
