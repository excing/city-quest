<view class="map-page">
  <map
    id="homeMap"
    class="map"
    longitude="{{longitude}}"
    latitude="{{latitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    include-points="{{includePoints}}"
    show-location="{{true}}"
    enable-3D="{{false}}"
    show-compass="{{false}}"
    enable-overlooking="{{false}}"
    bindmarkertap="onMarkerTap"
    bindlabeltap="onMarkerTap"
    bindtap="onMapTap"
    enable-poi="{{enablePoi}}"
  />

  <view class="map-banner map-banner--loading" wx:if="{{loading}}">
    <text>加载点位…</text>
  </view>

  <view class="map-banner map-banner--error" wx:elif="{{error}}" bindtap="onRetry">
    <text>{{error}}</text>
  </view>

  <view class="map-empty" wx:elif="{{empty}}">
    <view class="map-empty__title">暂时还没有点位</view>
    <button class="cq-btn-ghost" size="mini" bindtap="onRetry">刷新</button>
  </view>

  <!-- 点位签：外层只管落位与安全区，内层才是纸面签本体 -->
  <view
    class="preview-dock cq-safe-bottom"
    wx:if="{{preview}}"
    bindtap="onOpenDetail"
    hover-class="preview-dock--pressed"
  >
    <view class="preview-card">
      <view class="preview-card__bar" style="background: {{preview.typeColor}};"></view>
      <view class="preview-card__body">
        <view class="preview-card__head">
          <view class="preview-card__name">{{preview.name}}</view>
          <view class="preview-card__go" catchtap="onLocateHere">
            <text class="preview-card__go-label">定位到这里</text>
            <text class="preview-card__go-chevron">›</text>
          </view>
        </view>
        <view class="preview-card__type">
          <text class="cq-type-dot" style="background: {{preview.typeColor}};"></text>
          <text class="preview-card__type-name">{{preview.typeName}}</text>
        </view>
        <view class="preview-card__intro" wx:if="{{preview.intro}}">{{preview.intro}}</view>
      </view>
    </view>
  </view>
</view>
