/* Callers: about page. User: 阅读 docs 开始开发. */
.about-page {
  min-height: 100vh;
  background: var(--color-paper);
  padding: 48rpx 40rpx;
}

.about-page__title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-ink);
}

.about-page__lead {
  display: block;
  margin-top: 16rpx;
  font-size: 30rpx;
  color: var(--color-ink-secondary);
  line-height: 1.5;
}

.about-page__body {
  display: block;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: var(--color-ink);
  line-height: 1.65;
}
