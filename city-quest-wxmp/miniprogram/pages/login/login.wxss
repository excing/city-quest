/* Callers: login page. */
.login-page {
  min-height: 100vh;
  background: var(--color-paper);
  padding: 80rpx 48rpx;
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: 1.2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-avatar-btn::after {
  border: none;
}

.login-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-fill);
  border: 2rpx solid var(--color-line);
}

.login-avatar-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-ink-secondary);
}

.login-nickname {
  margin-top: 48rpx;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-surface);
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  color: var(--color-ink);
}

.login-agree {
  margin-top: 32rpx;
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-ink-secondary);
  line-height: 1.5;
}

.login-agree__text {
  flex: 1;
}

.login-link {
  color: var(--color-primary);
}

.login-submit {
  margin-top: 48rpx;
  width: 100%;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 500;
}

.btn--primary {
  background: var(--color-primary);
  color: #ffffff;
}

.btn--disabled,
.btn[disabled] {
  opacity: 0.55;
}
