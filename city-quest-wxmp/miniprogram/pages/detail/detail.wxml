<!-- Callers: map/history navigate. API: GET /public/encyclopedias/:id. User: 阅读 docs 开始开发. -->
<view class="detail-page" wx:if="{{loading}}">
  <view class="detail-page__state">加载中…</view>
</view>

<view class="detail-page" wx:elif="{{unavailable}}">
  <view class="detail-page__state">
    <text class="detail-page__state-title">该地点已下架，暂时无法查看</text>
    <button class="btn btn--primary" bindtap="onBackHome">返回首页</button>
  </view>
</view>

<view class="detail-page" wx:elif="{{detail}}">
  <swiper
    wx:if="{{detail.images.length > 0}}"
    class="detail-page__swiper"
    indicator-dots
    circular
  >
    <swiper-item wx:for="{{detail.images}}" wx:key="*this">
      <image class="detail-page__image" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <view class="detail-page__content">
    <text class="detail-page__name">{{detail.name}}</text>
    <view class="detail-page__type-row">
      <text class="detail-page__dot" style="color: {{typeColor}};">●</text>
      <text class="detail-page__type-name">{{typeName}}</text>
    </view>

    <view class="detail-page__tags" wx:if="{{detail.tags.length > 0}}">
      <text class="tag" wx:for="{{detail.tags}}" wx:key="*this">{{item}}</text>
    </view>

    <text class="detail-page__intro">{{detail.intro}}</text>

    <view class="detail-page__info" wx:if="{{detail.address}}">
      <text class="detail-page__info-label">地址</text>
      <text class="detail-page__info-value" bindtap="onOpenMap">{{detail.address}}</text>
      <text class="detail-page__info-action" bindtap="onOpenMap">导航</text>
    </view>
    <view class="detail-page__info" wx:if="{{detail.businessHours}}">
      <text class="detail-page__info-label">时间</text>
      <text class="detail-page__info-value">{{detail.businessHours}}</text>
    </view>
    <view class="detail-page__info" wx:if="{{detail.avgPrice}}">
      <text class="detail-page__info-label">人均</text>
      <text class="detail-page__info-value">{{detail.avgPrice}}</text>
    </view>
    <view class="detail-page__info" wx:if="{{detail.phone}}">
      <text class="detail-page__info-label">电话</text>
      <text class="detail-page__info-value" bindtap="onCall">{{detail.phone}}</text>
      <text class="detail-page__info-action" bindtap="onCall">呼叫</text>
    </view>
  </view>

  <view class="detail-page__footer safe-bottom">
    <button
      class="btn {{isFavorited ? 'btn--primary' : 'btn--secondary'}} detail-page__fav"
      loading="{{favLoading}}"
      disabled="{{favLoading}}"
      bindtap="onToggleFavorite"
    >
      {{isFavorited ? '已收藏' : '收藏'}}
    </button>
  </view>
</view>
