.detail-page {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.detail-loading {
  padding: 80rpx;
  text-align: center;
  color: var(--color-ink-secondary);
}

.detail-unavailable {
  min-height: 100vh;
}

.detail-gallery {
  width: 100%;
  height: 420rpx;
  background: var(--color-fill);
}

.detail-gallery__img {
  width: 100%;
  height: 100%;
}

.detail-body {
  padding: 32rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.3;
}

.detail-type {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-ink-secondary);
  display: flex;
  align-items: center;
}

.detail-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  font-size: 22rpx;
  line-height: 40rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  background: var(--color-fill);
  color: var(--color-ink-secondary);
}

.detail-intro {
  margin-top: 28rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--color-ink);
  white-space: pre-wrap;
}

.detail-meta {
  margin-top: 36rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.detail-meta__row {
  display: flex;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--color-line);
  gap: 24rpx;
}

.detail-meta__row:last-child {
  border-bottom: none;
}

.detail-meta__label {
  flex-shrink: 0;
  width: 140rpx;
  font-size: 26rpx;
  color: var(--color-ink-muted);
}

.detail-meta__value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-ink);
  line-height: 1.5;
}

.detail-meta__link {
  color: var(--color-primary);
}

.detail-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-sheet);
  z-index: 30;
}

.detail-fav {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-pill);
  font-size: 30rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.detail-fav--on {
  background: var(--color-primary);
  color: #fff;
}
