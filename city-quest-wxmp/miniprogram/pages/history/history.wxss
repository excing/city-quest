/* Callers: history page. User: 阅读 docs 开始开发. */
.history-page {
  min-height: 100vh;
  background: var(--color-paper);
  padding: 24rpx 32rpx 48rpx;
}

.history-page__toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.history-page__clear {
  color: var(--color-primary);
  font-size: 28rpx;
  padding: 8rpx 0;
}

.history-page__empty {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx;
}

.history-page__empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
}

.history-page__empty-desc {
  font-size: 26rpx;
  color: var(--color-ink-secondary);
  margin-bottom: 24rpx;
  text-align: center;
}

.history-list {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-line);
  overflow: hidden;
}

.history-row {
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.history-row + .history-row {
  border-top: 1rpx solid var(--color-line);
}

.history-row__cover {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-sm);
  background: var(--color-fill);
  flex-shrink: 0;
}

.history-row__body {
  flex: 1;
  min-width: 0;
}

.history-row__name {
  display: block;
  font-size: 30rpx;
  color: var(--color-ink);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-row__meta {
  margin-top: 8rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-ink-secondary);
}

.history-row__dot {
  font-size: 20rpx;
}

.history-row__time {
  margin-left: auto;
  color: var(--color-ink-muted);
  font-variant-numeric: tabular-nums;
}

.history-row__chevron {
  color: var(--color-ink-muted);
  font-size: 34rpx;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  padding: 0 40rpx;
}

.btn--primary {
  background: var(--color-primary);
  color: #ffffff;
}
