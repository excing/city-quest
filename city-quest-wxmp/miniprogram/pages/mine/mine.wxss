.mine-page {
  padding: 32rpx 0 48rpx;
}

.mine-card {
  margin: 0 32rpx 8rpx;
  padding: 32rpx;
}

.mine-user {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.mine-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-fill);
  flex-shrink: 0;
}

.mine-avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: 36rpx;
  font-weight: 600;
  background: var(--color-primary-soft);
}

.mine-user__info {
  flex: 1;
  min-width: 0;
}

.mine-user__name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine-user__hint {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--color-ink-muted);
}

.mine-user__chevron {
  color: var(--color-ink-muted);
  font-size: 36rpx;
  line-height: 1;
}

.mine-logout-cell {
  justify-content: center;
}

.mine-logout-cell__title {
  width: 100%;
  text-align: center;
  color: var(--color-danger, #e54d42);
  font-weight: 500;
}

.mine-guest__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
}

.mine-guest__desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-ink-secondary);
  line-height: 1.5;
}

.mine-guest__btn {
  margin-top: 28rpx;
  width: 100%;
}

.mine-cell--pressed {
  background: var(--color-fill);
}
