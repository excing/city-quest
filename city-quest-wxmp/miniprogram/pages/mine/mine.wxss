.page {
  padding: 32rpx;
  background: var(--color-paper);
  color: var(--color-ink);
  min-height: 100vh;
}
.title { font-size: 36rpx; font-weight: 600; margin-bottom: 24rpx; }
.row { margin-bottom: 16rpx; color: var(--color-ink-secondary); }
button { margin: 12rpx 0; }
.hint { margin-top: 32rpx; font-size: 24rpx; color: var(--color-ink-muted); }
