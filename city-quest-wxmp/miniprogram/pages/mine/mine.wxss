.mine-page {
  min-height: 100vh;
  background: var(--color-paper);
  padding: 32rpx;
}

.mine-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-line);
  padding: 32rpx;
}

.mine-card__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-ink);
}

.mine-card__desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-ink-secondary);
}

.mine-card--user {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.mine-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-fill);
  flex-shrink: 0;
}

.mine-card__info {
  flex: 1;
  min-width: 0;
}

.mine-card__logout {
  color: var(--color-primary);
  font-size: 28rpx;
  padding: 12rpx;
}

.mine-card__btn {
  margin-top: 24rpx;
  width: 100%;
}

.btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
}

.btn--primary {
  background: var(--color-primary);
  color: #ffffff;
}


.mine-group {
  margin-top: 24rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-line);
  overflow: hidden;
}

.list-cell {
  min-height: 104rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.list-cell + .list-cell {
  border-top: 1rpx solid var(--color-line);
}

.list-cell__label {
  font-size: 30rpx;
  color: var(--color-ink);
}

.list-cell__chevron {
  font-size: 36rpx;
  color: var(--color-ink-muted);
}
