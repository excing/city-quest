<view class="mine-page cq-page cq-safe-bottom">
  <view class="mine-card cq-card">
    <block wx:if="{{loggedIn}}">
      <view class="mine-user" bindtap="goProfile">
        <image
          class="mine-avatar"
          wx:if="{{avatarUrl}}"
          src="{{avatarUrl}}"
          mode="aspectFill"
        />
        <view class="mine-avatar mine-avatar--placeholder" wx:else>探</view>
        <view class="mine-user__info">
          <view class="mine-user__name">{{nickname}}</view>
          <view class="mine-user__hint">点击编辑资料</view>
        </view>
        <text class="mine-user__chevron">›</text>
      </view>
    </block>
    <block wx:else>
      <view class="mine-guest">
        <view class="mine-guest__title">登录后同步收藏</view>
        <view class="mine-guest__desc">换手机也能查看你收藏的地点</view>
        <button class="cq-btn-primary mine-guest__btn" bindtap="goLogin">登录</button>
      </view>
    </block>
  </view>

  <view class="cq-list">
    <view
      class="cq-list-cell"
      wx:if="{{loggedIn}}"
      bindtap="goFavorites"
      hover-class="mine-cell--pressed"
    >
      <view class="cq-list-cell__main">
        <view class="cq-list-cell__title">我的收藏</view>
      </view>
      <text class="cq-list-cell__chevron">›</text>
    </view>
    <view class="cq-list-cell" bindtap="goHistory" hover-class="mine-cell--pressed">
      <view class="cq-list-cell__main">
        <view class="cq-list-cell__title">浏览记录</view>
      </view>
      <text class="cq-list-cell__chevron">›</text>
    </view>
  </view>

  <view class="cq-list">
    <view class="cq-list-cell" bindtap="goSettings" hover-class="mine-cell--pressed">
      <view class="cq-list-cell__main">
        <view class="cq-list-cell__title">设置</view>
      </view>
      <text class="cq-list-cell__chevron">›</text>
    </view>
  </view>

  <view class="cq-list" wx:if="{{loggedIn}}">
    <view class="cq-list-cell mine-logout-cell" bindtap="onLogout" hover-class="mine-cell--pressed">
      <view class="cq-list-cell__main">
        <view class="cq-list-cell__title mine-logout-cell__title">退出登录</view>
      </view>
    </view>
  </view>
</view>
