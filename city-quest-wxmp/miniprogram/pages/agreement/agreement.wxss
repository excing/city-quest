.legal-page {
  min-height: 100vh;
  background: var(--color-paper);
  padding: 40rpx 36rpx 80rpx;
}
.legal-page__title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-ink);
  margin-bottom: 24rpx;
}
.legal-page__h {
  display: block;
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-ink);
}
.legal-page__p {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--color-ink-secondary);
}
