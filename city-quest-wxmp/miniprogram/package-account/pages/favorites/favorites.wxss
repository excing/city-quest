/* Callers: favorites.wxml. No API/schema. User: 实现阶段3. */
.fav-page {
  min-height: 100vh;
}

.detail-loading {
  padding: 80rpx;
  text-align: center;
  color: var(--color-ink-secondary);
}

.fav-list {
  margin: 24rpx 32rpx 32rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.fav-row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-line);
  gap: 12rpx;
}

.fav-row:last-child {
  border-bottom: none;
}

.fav-row--off .fav-name,
.fav-row--off .fav-sub {
  color: var(--color-ink-muted);
}

.fav-row__main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.fav-info {
  flex: 1;
  min-width: 0;
}

.fav-name {
  font-size: 30rpx;
  color: var(--color-ink);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
}

.fav-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-ink-secondary);
  display: flex;
  align-items: center;
}

.fav-remove {
  margin: 0;
  flex-shrink: 0;
  background: var(--color-danger-soft);
  color: var(--color-danger);
  font-size: 22rpx;
  line-height: 52rpx;
  height: 52rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
}
