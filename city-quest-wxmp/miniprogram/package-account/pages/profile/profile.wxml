<!-- Profile edit: avatar / nickname / phone. Callers: mine user card. -->
<view class="profile-page cq-page cq-safe-bottom">
  <view class="profile-card cq-card">
    <view class="profile-avatar-row">
      <button
        class="profile-avatar-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <image
          class="profile-avatar"
          wx:if="{{displayAvatarUrl}}"
          src="{{displayAvatarUrl}}"
          mode="aspectFill"
        />
        <view class="profile-avatar profile-avatar--placeholder" wx:else>探</view>
      </button>
      <view class="profile-avatar-hint">点击更换头像</view>
    </view>

    <view class="profile-field">
      <view class="profile-label">昵称</view>
      <input
        class="profile-input"
        type="nickname"
        maxlength="64"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <view class="profile-field">
      <view class="profile-label">手机号</view>
      <input
        class="profile-input"
        type="number"
        maxlength="11"
        placeholder="选填"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>
  </view>

  <button
    class="cq-btn-primary profile-save"
    loading="{{saving}}"
    disabled="{{saving}}"
    bindtap="onSave"
  >
    保存
  </button>
</view>
