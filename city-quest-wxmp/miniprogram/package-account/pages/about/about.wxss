.static-page {
  padding: 48rpx 40rpx 64rpx;
}

.static-hero {
  margin-bottom: 40rpx;
}

.static-hero__name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-ink);
}

.static-hero__tagline {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-ink-secondary);
  line-height: 1.5;
}

.static-body {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}

.static-p {
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--color-ink);
  margin-bottom: 24rpx;
}

.static-p:last-child {
  margin-bottom: 0;
}

.static-muted {
  color: var(--color-ink-muted);
  font-size: 24rpx;
}
