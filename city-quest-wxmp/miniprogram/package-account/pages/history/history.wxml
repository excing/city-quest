<view class="history-page cq-page cq-safe-bottom">
  <view class="history-toolbar" wx:if="{{!empty}}">
    <text class="history-clear" bindtap="onClear">清空</text>
  </view>

  <view class="cq-empty" wx:if="{{empty}}">
    <view class="cq-empty__title">还没有浏览记录</view>
    <view class="cq-empty__desc">打开地点详情后，会自动记在这里</view>
    <button class="cq-btn-ghost" bindtap="goMap">去地图看看</button>
  </view>

  <view class="history-list" wx:else>
    <view
      class="history-row"
      wx:for="{{items}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onOpen"
      hover-class="history-row--pressed"
    >
      <list-cover
        src="{{item.coverUrl}}"
        name="{{item.name}}"
        typeColor="{{item.typeColor}}"
      />
      <view class="history-main">
        <view class="history-name">{{item.name}}</view>
        <view class="history-sub">
          <text class="cq-type-dot" style="background: {{item.typeColor}};"></text>
          <text>{{item.typeName}}</text>
          <text class="history-time" wx:if="{{item.viewedAtLabel}}"> · {{item.viewedAtLabel}}</text>
        </view>
      </view>
      <text class="cq-list-cell__chevron">›</text>
    </view>
  </view>
</view>
