.static-page {
  padding: 32rpx 40rpx 64rpx;
}

.static-body {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}

.static-h {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-ink);
  margin: 28rpx 0 12rpx;
}

.static-h:first-child {
  margin-top: 0;
}

.static-p {
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--color-ink-secondary);
  margin-bottom: 8rpx;
}

.static-muted {
  margin-top: 32rpx;
  color: var(--color-ink-muted);
  font-size: 24rpx;
}
